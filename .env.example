# Application
NODE_ENV=development
PORT=8080

# MongoDB (local)
MONGO_URL=mongodb://127.0.0.1:27017/bookshelf

# Session Secret (change this to any random string)
SESSION_SECRET=your-secret-key-here
SECRET=your-secret-key-here

# Cloudinary (for book cover image uploads)
# Get free account at https://cloudinary.com
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# Email (Gmail with App Password)
# Enable 2FA on Gmail, then generate App Password
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Library System <noreply@library.com>"
APP_URL=http://localhost:8080

# Library Settings
LATE_FINE_PER_DAY=5
MAX_BORROW_DAYS=14
MAX_BOOKS_PER_USER=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
