<% layout(isAdmin || isLibrarian ? "/layouts/admin" : "/layouts/boilerplate") %>

<div class="row justify-content-center py-4">
  <div class="col-lg-8">
    <div class="glass-card overflow-hidden anim-up">
      <div style="height:6px;background:var(--grad-forest);"></div>
      <div class="p-4 p-md-5">
        <div style="width:56px;height:56px;border-radius:14px;background:var(--grad-forest);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;margin-bottom:1.5rem;">
          <i class="fa-solid fa-file-pdf"></i>
        </div>
        <h1 style="font-size:1.7rem;font-weight:800;color:#1a1a2e;margin-bottom:1rem;line-height:1.3;"><%= paper.title %></h1>

        <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;font-size:0.85rem;color:#888;">
          <span><i class="fa-solid fa-user me-1" style="color:#43e97b;"></i><%= paper.uploadedBy ? paper.uploadedBy.username : 'Unknown' %></span>
          <span><i class="fa-solid fa-tag me-1" style="color:#4facfe;"></i><%= paper.category || 'Other' %></span>
          <span><i class="fa-solid fa-calendar me-1"></i><%= paper.createdAt ? new Date(paper.createdAt).toLocaleDateString() : '' %></span>
          <span><i class="fa-solid fa-download me-1" style="color:#667eea;"></i><%= paper.downloads || 0 %> downloads</span>
          <span>
            <% if (paper.status === 'Approved') { %><span class="badge" style="background:var(--grad-forest);">Approved</span>
            <% } else if (paper.status === 'Pending') { %><span class="badge" style="background:var(--grad-sunset);">Pending Review</span>
            <% } else { %><span class="badge" style="background:var(--grad-fire);">Rejected</span><% } %>
          </span>
        </div>

        <% if (paper.abstract) { %>
        <div style="background:rgba(67,233,123,0.06);border-radius:14px;padding:1.2rem;margin-bottom:1.5rem;border-left:4px solid #43e97b;">
          <div style="font-size:0.75rem;font-weight:700;color:#43e97b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.5rem;">Abstract</div>
          <p style="color:#444;line-height:1.8;margin:0;font-size:0.95rem;"><%= paper.abstract %></p>
        </div>
        <% } %>

        <% if (paper.keywords && paper.keywords.length > 0) { %>
        <div style="margin-bottom:1.5rem;">
          <div style="font-size:0.75rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.6rem;">Keywords</div>
          <% for (let kw of paper.keywords) { %>
          <span style="display:inline-block;background:rgba(67,233,123,0.1);color:#2d8a5e;border-radius:50px;padding:0.25rem 0.8rem;font-size:0.82rem;font-weight:600;margin:0.2rem;">#<%= kw %></span>
          <% } %>
        </div>
        <% } %>

        <div class="d-flex gap-3 flex-wrap">
          <% if (paper.pdfFile && paper.pdfFile.url) { %>
          <a href="/research/<%= paper._id %>/download" class="btn btn-grad">
            <i class="fa-solid fa-download me-2"></i>Download PDF
          </a>
          <% } %>
          <% if (currUser && paper.uploadedBy && (currUser._id.toString() === paper.uploadedBy._id.toString() || isAdmin)) { %>
          <form method="POST" action="/research/<%= paper._id %>?_method=DELETE">
            <button type="submit" class="btn btn-outline-danger" style="border-radius:50px;">
              <i class="fa-solid fa-trash me-2"></i>Delete
            </button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
    <div class="mt-3">
      <a href="/research" style="color:#43e97b;text-decoration:none;font-weight:600;font-size:0.9rem;">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Research
      </a>
    </div>
  </div>
</div>
