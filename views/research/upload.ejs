<% layout(isAdmin || isLibrarian ? "/layouts/admin" : "/layouts/boilerplate") %>

<div class="row justify-content-center py-4">
  <div class="col-lg-7">
    <div class="text-center mb-4 anim-down">
      <div style="width:64px;height:64px;border-radius:50%;background:var(--grad-forest);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.6rem;color:#fff;box-shadow:0 8px 24px rgba(67,233,123,0.4);">
        <i class="fa-solid fa-upload"></i>
      </div>
      <h2 style="font-size:1.6rem;font-weight:800;background:var(--grad-forest);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Upload Research Paper</h2>
      <p style="color:#888;font-size:0.9rem;">Share your academic work with the community</p>
    </div>
    <div class="form-wrapper anim-up">
      <form action="/research" method="POST" enctype="multipart/form-data" novalidate>
        <div class="mb-3">
          <label class="form-label">Paper Title <span style="color:#f5576c;">*</span></label>
          <input type="text" name="title" class="form-control" placeholder="Enter the paper title" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Abstract</label>
          <textarea name="abstract" class="form-control" rows="5" placeholder="Brief summary of your research..."></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Category</label>
          <select name="category" class="form-select">
            <% ['Computer Science','Engineering','Mathematics','Physics','Chemistry','Biology','Medicine','Social Sciences','Business','Arts','Other'].forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Keywords <span style="color:#aaa;font-size:0.82rem;">(comma separated)</span></label>
          <input type="text" name="keywords" class="form-control" placeholder="e.g. machine learning, AI, neural networks" />
        </div>
        <div class="mb-4">
          <label class="form-label">PDF File <span style="color:#f5576c;">*</span></label>
          <input type="file" name="pdfFile" class="form-control" accept=".pdf" required />
          <div style="font-size:0.8rem;color:#aaa;margin-top:0.3rem;">Only PDF files are accepted</div>
        </div>
        <div class="d-flex gap-3">
          <button type="submit" class="btn btn-grad flex-fill" style="padding:0.8rem;background:var(--grad-forest);">
            <i class="fa-solid fa-upload me-2"></i>Upload Paper
          </button>
          <a href="/research" class="btn btn-outline-secondary flex-fill" style="border-radius:50px;padding:0.8rem;">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
