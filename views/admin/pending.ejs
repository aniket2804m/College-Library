<% layout("/layouts/admin") %>

<div class="anim-down mb-4 d-flex justify-content-between align-items-center">
  <div>
    <h2 class="section-title mb-1"><i class="fa-solid fa-user-clock me-2"></i>Pending Approvals</h2>
    <p style="color:#888;font-size:0.9rem;">Librarian accounts waiting for admin approval</p>
  </div>
  <a href="/admin/users" class="btn btn-grad"><i class="fa-solid fa-users me-2"></i>All Users</a>
</div>

<% if (users.length === 0) { %>
<div class="glass-card p-5 text-center anim-up">
  <i class="fa-solid fa-circle-check" style="font-size:3rem;color:#43e97b;margin-bottom:1rem;display:block;"></i>
  <h5 style="color:#1a1a2e;font-weight:700;">All caught up!</h5>
  <p style="color:#888;">No pending account approvals right now.</p>
</div>
<% } else { %>
<div class="glass-card p-4 anim-up">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead style="background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;">
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Role Requested</th>
          <th>Department</th>
          <th>Registered</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(user => { %>
        <tr>
          <td>
            <div class="d-flex align-items-center gap-2">
              <div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#f093fb,#f5576c);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0;">
                <%= user.username.charAt(0).toUpperCase() %>
              </div>
              <strong><%= user.username %></strong>
            </div>
          </td>
          <td style="font-size:0.88rem;color:#666;"><%= user.email %></td>
          <td>
            <span class="badge bg-warning text-dark">
              <i class="fa-solid fa-book me-1"></i><%= user.role %>
            </span>
          </td>
          <td style="font-size:0.88rem;color:#666;"><%= user.department || '—' %></td>
          <td style="font-size:0.82rem;color:#888;"><%= user.createdAt ? new Date(user.createdAt).toLocaleDateString() : '—' %></td>
          <td>
            <div class="d-flex gap-2">
              <form method="POST" action="/admin/users/<%= user._id %>/approve">
                <button class="btn btn-sm btn-success" style="border-radius:50px;font-size:0.78rem;">
                  <i class="fa-solid fa-check me-1"></i>Approve
                </button>
              </form>
              <form method="POST" action="/admin/users/<%= user._id %>/reject" onsubmit="return confirm('Reject and delete this account?')">
                <button class="btn btn-sm btn-outline-danger" style="border-radius:50px;font-size:0.78rem;">
                  <i class="fa-solid fa-xmark me-1"></i>Reject
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>
