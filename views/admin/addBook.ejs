<% layout("/layouts/admin") %>

<div class="anim-down mb-4 d-flex justify-content-between align-items-center">
  <div>
    <h2 class="section-title mb-1"><i class="fa-solid fa-plus me-2"></i>Add New Book</h2>
    <p style="color:#888;font-size:0.9rem;">Add a book to the library catalog</p>
  </div>
  <a href="/admin/books" class="btn btn-grad"><i class="fa-solid fa-arrow-left me-2"></i>Back to Books</a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="glass-card p-4 anim-up">
      <form action="/admin/books/new" method="POST" enctype="multipart/form-data" novalidate>

        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Book Title <span class="text-danger">*</span></label>
            <input type="text" name="listing[title]" class="form-control" placeholder="e.g. Clean Code" required />
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Author <span class="text-danger">*</span></label>
            <input type="text" name="listing[author]" id="authorInput" class="form-control" placeholder="e.g. Robert C. Martin" required />
            <input type="hidden" name="listing[country]" id="countryHidden" value="" />
          </div>

          <div class="col-md-6">
            <label class="form-label fw-semibold">Category</label>
            <select name="listing[category]" class="form-select">
              <% ['Fiction','Non-Fiction','Science','Technology','History','Biography','Self-Help','Business','Education','Programming','Mathematics','Physics','Chemistry','Literature','Philosophy','Psychology','Other'].forEach(cat => { %>
              <option value="<%= cat %>"><%= cat %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Shelf / Location</label>
            <input type="text" name="listing[location]" class="form-control" placeholder="e.g. Shelf A-3" />
          </div>

          <div class="col-md-4">
            <label class="form-label fw-semibold">Total Quantity <span class="text-danger">*</span></label>
            <input type="number" name="listing[totalQuantity]" id="totalQty" class="form-control" placeholder="e.g. 5" min="1" required />
            <input type="hidden" name="listing[price]" id="priceHidden" value="1" />
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">Available Qty</label>
            <input type="number" name="listing[availableQuantity]" id="availQty" class="form-control" placeholder="Same as total" min="0" />
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">ISBN</label>
            <input type="text" name="listing[isbn]" class="form-control" placeholder="e.g. 978-3-16-148410-0" />
          </div>

          <div class="col-md-6">
            <label class="form-label fw-semibold">Publisher</label>
            <input type="text" name="listing[publisher]" class="form-control" placeholder="e.g. Pearson" />
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Published Year</label>
            <input type="number" name="listing[publishedYear]" class="form-control" placeholder="e.g. 2020" />
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Pages</label>
            <input type="number" name="listing[pages]" class="form-control" placeholder="e.g. 320" />
          </div>

          <div class="col-12">
            <label class="form-label fw-semibold">Description</label>
            <textarea name="listing[description]" class="form-control" rows="3" placeholder="Brief description of the book..."></textarea>
          </div>

          <div class="col-12">
            <label class="form-label fw-semibold">Book Cover Image</label>
            <input type="file" name="image" class="form-control" accept="image/*" />
            <div class="form-text">Supported: JPG, PNG, WEBP</div>
          </div>
        </div>

        <div class="mt-4 d-flex gap-3">
          <button type="submit" class="btn btn-grad px-5" style="padding:0.75rem 2rem;">
            <i class="fa-solid fa-plus me-2"></i>Add Book
          </button>
          <a href="/admin/books" class="btn btn-outline-secondary px-4" style="border-radius:50px;">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.getElementById('totalQty').addEventListener('input', function() {
    document.getElementById('priceHidden').value = this.value || 1;
    const avail = document.getElementById('availQty');
    if (!avail.value) avail.value = this.value;
  });
  document.getElementById('authorInput').addEventListener('input', function() {
    document.getElementById('countryHidden').value = this.value;
  });
</script>
