<% layout("/layouts/admin") %>

<div class="py-3">
  <div class="d-flex justify-content-between align-items-center mb-4 anim-down">
    <h2 class="section-title mb-0"><i class="fa-solid fa-newspaper me-2"></i>Blog Management</h2>
    <div class="d-flex gap-2">
      <a href="/admin/blogs/new" class="btn btn-grad"><i class="fa-solid fa-plus me-2"></i>New Blog</a>
      <a href="/admin/dashboard" class="btn btn-outline-secondary" style="border-radius:50px;"><i class="fa-solid fa-arrow-left me-2"></i>Dashboard</a>
    </div>
  </div>

  <div class="glass-card p-4 anim-up">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead style="background:linear-gradient(135deg,#fa709a,#fee140);color:#1a1a2e;">
          <tr><th>Title</th><th>Author</th><th>Category</th><th>Views</th><th>Likes</th><th>Date</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% blogs.forEach(blog => { %>
          <tr>
            <td style="font-weight:600;font-size:0.88rem;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= blog.title %></td>
            <td style="font-size:0.85rem;"><%= blog.author ? blog.author.username : '-' %></td>
            <td><span class="badge bg-primary" style="font-size:0.72rem;"><%= blog.category || 'General' %></span></td>
            <td style="font-size:0.85rem;"><%= blog.views || 0 %></td>
            <td style="font-size:0.85rem;"><%= blog.likesCount || 0 %></td>
            <td style="font-size:0.78rem;color:#888;"><%= blog.createdAt ? new Date(blog.createdAt).toLocaleDateString() : '-' %></td>
            <td>
              <div class="d-flex gap-1">
                <a href="/blogs/<%= blog._id %>" class="btn btn-sm btn-outline-primary" style="border-radius:50px;font-size:0.75rem;">View</a>
                <a href="/admin/blogs/<%= blog._id %>/edit" class="btn btn-sm btn-outline-warning" style="border-radius:50px;font-size:0.75rem;">Edit</a>
                <% if (isAdmin) { %>
                <form method="POST" action="/admin/blogs/<%= blog._id %>/delete" onsubmit="return confirm('Delete this blog?')">
                  <button class="btn btn-sm btn-outline-danger" style="border-radius:50px;font-size:0.75rem;">Delete</button>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (blogs.length === 0) { %>
          <tr><td colspan="7" class="text-center py-4" style="color:#aaa;">No blogs found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
