<% layout("/layouts/admin") %>

<div class="py-3">
  <div class="d-flex justify-content-between align-items-center mb-4 anim-down">
    <h2 class="section-title mb-0"><i class="fa-solid fa-flask me-2"></i>Research Paper Management</h2>
    <a href="/admin/dashboard" class="btn btn-outline-secondary" style="border-radius:50px;"><i class="fa-solid fa-arrow-left me-2"></i>Dashboard</a>
  </div>

  <!-- Filter -->
  <div class="glass-card p-3 mb-4 anim-down d-flex gap-2 flex-wrap">
    <a href="/admin/research" class="btn btn-sm <%= !filterStatus ? 'btn-grad' : 'btn-outline-secondary' %>" style="border-radius:50px;">All</a>
    <a href="/admin/research?status=Pending" class="btn btn-sm <%= filterStatus==='Pending' ? 'btn-grad' : 'btn-outline-warning' %>" style="border-radius:50px;">Pending</a>
    <a href="/admin/research?status=Approved" class="btn btn-sm <%= filterStatus==='Approved' ? 'btn-grad' : 'btn-outline-success' %>" style="border-radius:50px;">Approved</a>
    <a href="/admin/research?status=Rejected" class="btn btn-sm <%= filterStatus==='Rejected' ? 'btn-grad' : 'btn-outline-danger' %>" style="border-radius:50px;">Rejected</a>
  </div>

  <div class="glass-card p-4 anim-up">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead style="background:linear-gradient(135deg,#43e97b,#38f9d7);color:#1a1a2e;">
          <tr><th>Title</th><th>Uploaded By</th><th>Category</th><th>Status</th><th>Date</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% papers.forEach(paper => { %>
          <tr>
            <td style="font-weight:600;font-size:0.88rem;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= paper.title %></td>
            <td style="font-size:0.85rem;"><%= paper.uploadedBy ? paper.uploadedBy.username : '-' %></td>
            <td style="font-size:0.82rem;color:#666;"><%= paper.category || '-' %></td>
            <td>
              <span class="badge bg-<%= paper.status === 'Approved' ? 'success' : paper.status === 'Rejected' ? 'danger' : 'warning text-dark' %>">
                <%= paper.status %>
              </span>
            </td>
            <td style="font-size:0.78rem;color:#888;"><%= paper.createdAt ? new Date(paper.createdAt).toLocaleDateString() : '-' %></td>
            <td>
              <div class="d-flex gap-1 flex-wrap">
                <a href="/research/<%= paper._id %>" class="btn btn-sm btn-outline-primary" style="border-radius:50px;font-size:0.75rem;">View</a>
                <% if (paper.status === 'Pending') { %>
                <form method="POST" action="/admin/research/<%= paper._id %>/approve">
                  <button class="btn btn-sm btn-success" style="border-radius:50px;font-size:0.75rem;">Approve</button>
                </form>
                <form method="POST" action="/admin/research/<%= paper._id %>/reject">
                  <button class="btn btn-sm btn-danger" style="border-radius:50px;font-size:0.75rem;">Reject</button>
                </form>
                <% } %>
                <% if (isAdmin) { %>
                <form method="POST" action="/admin/research/<%= paper._id %>/delete" onsubmit="return confirm('Delete this paper?')">
                  <button class="btn btn-sm btn-outline-danger" style="border-radius:50px;font-size:0.75rem;">Delete</button>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (papers.length === 0) { %>
          <tr><td colspan="6" class="text-center py-4" style="color:#aaa;">No research papers found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
