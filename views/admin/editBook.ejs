<% layout("/layouts/admin") %>

<div class="anim-down mb-4 d-flex justify-content-between align-items-center">
  <div>
    <h2 class="section-title mb-1"><i class="fa-solid fa-pen me-2"></i>Edit Book</h2>
    <p style="color:#888;font-size:0.9rem;">Update details for "<%= listing.title %>"</p>
  </div>
  <a href="/admin/books" class="btn btn-grad"><i class="fa-solid fa-arrow-left me-2"></i>Back to Books</a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="glass-card p-4 anim-up">
      <form action="/admin/books/<%= listing._id %>/edit" method="POST" enctype="multipart/form-data" novalidate>

        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Book Title <span class="text-danger">*</span></label>
            <input type="text" name="listing[title]" class="form-control" value="<%= listing.title %>" required />
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Author</label>
            <input type="text" name="listing[author]" class="form-control" value="<%= listing.author || listing.country || '' %>" />
            <input type="hidden" name="listing[country]" value="<%= listing.author || listing.country || '' %>" />
          </div>

          <div class="col-md-6">
            <label class="form-label fw-semibold">Category</label>
            <select name="listing[category]" class="form-select">
              <% ['Fiction','Non-Fiction','Science','Technology','History','Biography','Self-Help','Business','Education','Programming','Mathematics','Physics','Chemistry','Literature','Philosophy','Psychology','Other'].forEach(cat => { %>
              <option value="<%= cat %>" <%= listing.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Shelf / Location</label>
            <input type="text" name="listing[location]" class="form-control" value="<%= listing.location || '' %>" />
          </div>

          <div class="col-md-4">
            <label class="form-label fw-semibold">Total Quantity</label>
            <input type="number" name="listing[totalQuantity]" class="form-control" value="<%= listing.totalQuantity || listing.price || 1 %>" min="1" />
            <input type="hidden" name="listing[price]" value="<%= listing.totalQuantity || listing.price || 1 %>" />
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">Available Qty</label>
            <input type="number" name="listing[availableQuantity]" class="form-control" value="<%= listing.availableQuantity || 0 %>" min="0" />
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">ISBN</label>
            <input type="text" name="listing[isbn]" class="form-control" value="<%= listing.isbn || '' %>" />
          </div>

          <div class="col-md-6">
            <label class="form-label fw-semibold">Publisher</label>
            <input type="text" name="listing[publisher]" class="form-control" value="<%= listing.publisher || '' %>" />
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Published Year</label>
            <input type="number" name="listing[publishedYear]" class="form-control" value="<%= listing.publishedYear || '' %>" />
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold">Pages</label>
            <input type="number" name="listing[pages]" class="form-control" value="<%= listing.pages || '' %>" />
          </div>

          <div class="col-12">
            <label class="form-label fw-semibold">Description</label>
            <textarea name="listing[description]" class="form-control" rows="3"><%= listing.description || '' %></textarea>
          </div>

          <% if (listing.image && listing.image.url) { %>
          <div class="col-12">
            <label class="form-label fw-semibold">Current Cover</label>
            <div style="border-radius:12px;overflow:hidden;max-height:160px;max-width:120px;">
              <img src="<%= listing.image.url %>" alt="cover" style="width:100%;height:160px;object-fit:cover;" />
            </div>
          </div>
          <% } %>

          <div class="col-12">
            <label class="form-label fw-semibold">Replace Cover Image</label>
            <input type="file" name="image" class="form-control" accept="image/*" />
          </div>
        </div>

        <div class="mt-4 d-flex gap-3">
          <button type="submit" class="btn btn-grad px-5" style="padding:0.75rem 2rem;">
            <i class="fa-solid fa-floppy-disk me-2"></i>Save Changes
          </button>
          <a href="/admin/books" class="btn btn-outline-secondary px-4" style="border-radius:50px;">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
