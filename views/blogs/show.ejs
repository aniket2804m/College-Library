<% layout(isAdmin || isLibrarian ? "/layouts/admin" : "/layouts/boilerplate") %>

<div class="row justify-content-center py-4">
  <div class="col-lg-8">
    <div class="glass-card overflow-hidden anim-up">
      <!-- Header gradient bar -->
      <div style="height:6px;background:var(--grad-primary);"></div>
      <div class="p-4 p-md-5">
        <!-- Category + Date -->
        <div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:1.2rem;flex-wrap:wrap;">
          <span style="font-size:0.78rem;font-weight:700;background:rgba(102,126,234,0.1);color:#667eea;padding:0.25rem 0.8rem;border-radius:50px;">
            <%= blog.category || 'General' %>
          </span>
          <span style="font-size:0.8rem;color:#aaa;"><i class="fa-solid fa-calendar me-1"></i><%= blog.createdAt ? new Date(blog.createdAt).toLocaleDateString() : '' %></span>
          <span style="font-size:0.8rem;color:#aaa;"><i class="fa-solid fa-user me-1"></i><%= blog.author ? blog.author.username : 'Unknown' %></span>
        </div>

        <h1 style="font-size:1.8rem;font-weight:800;color:#1a1a2e;margin-bottom:1.5rem;line-height:1.3;"><%= blog.title %></h1>

        <div style="color:#444;line-height:1.9;font-size:1rem;white-space:pre-wrap;"><%= blog.content %></div>

        <!-- Tags -->
        <% if (blog.tags && blog.tags.length > 0) { %>
        <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid #f0f0f0;">
          <% for (let tag of blog.tags) { %>
          <span style="display:inline-block;background:rgba(102,126,234,0.08);color:#667eea;border-radius:50px;padding:0.25rem 0.8rem;font-size:0.8rem;font-weight:600;margin:0.2rem;">#<%= tag %></span>
          <% } %>
        </div>
        <% } %>

        <!-- Actions -->
        <% if (currUser && blog.author && (currUser.username === blog.author.username || isAdmin)) { %>
        <div class="d-flex gap-3 mt-4">
          <a href="/blogs/<%= blog._id %>/edit" class="btn btn-outline-primary" style="border-radius:50px;">
            <i class="fa-solid fa-pen me-2"></i>Edit
          </a>
          <form method="POST" action="/blogs/<%= blog._id %>?_method=DELETE">
            <button type="submit" class="btn btn-outline-danger" style="border-radius:50px;">
              <i class="fa-solid fa-trash me-2"></i>Delete
            </button>
          </form>
        </div>
        <% } %>

        <!-- Like Button -->
        <% if (currUser) { %>
        <div class="mt-4 pt-3" style="border-top:1px solid #f0f0f0;">
          <button id="likeBtn" onclick="toggleLike()" class="btn btn-sm" style="border-radius:50px;background:rgba(245,87,108,0.1);color:#f5576c;border:1px solid rgba(245,87,108,0.2);font-weight:600;">
            <i class="fa-solid fa-heart me-1"></i><span id="likeCount"><%= blog.likesCount || 0 %></span> Likes
          </button>
        </div>
        <% } else { %>
        <div class="mt-4 pt-3" style="border-top:1px solid #f0f0f0;">
          <span style="color:#aaa;font-size:0.88rem;"><i class="fa-solid fa-heart me-1" style="color:#f5576c;"></i><%= blog.likesCount || 0 %> likes</span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Comments Section -->
    <div class="glass-card p-4 mt-4 anim-up" style="animation-delay:0.1s;">
      <h5 class="section-title mb-3"><i class="fa-solid fa-comments me-2"></i>Comments (<%= blog.commentsCount || 0 %>)</h5>

      <% if (currUser) { %>
      <form method="POST" action="/blogs/<%= blog._id %>/comment" class="mb-4">
        <div class="d-flex gap-2">
          <input type="text" name="comment" class="form-control" placeholder="Write a comment..." required style="border-radius:50px;" />
          <button type="submit" class="btn btn-grad px-3" style="white-space:nowrap;"><i class="fa-solid fa-paper-plane"></i></button>
        </div>
      </form>
      <% } %>

      <% if (blog.comments && blog.comments.length > 0) { %>
      <div style="display:flex;flex-direction:column;gap:0.8rem;">
        <% for (let c of blog.comments) { %>
        <div style="display:flex;align-items:flex-start;gap:0.8rem;padding:0.8rem;background:rgba(102,126,234,0.04);border-radius:12px;">
          <div style="width:34px;height:34px;border-radius:50%;background:var(--grad-primary);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0;">
            <%= c.user && c.user.username ? c.user.username.charAt(0).toUpperCase() : '?' %>
          </div>
          <div style="flex:1;">
            <div style="font-weight:700;font-size:0.85rem;color:#1a1a2e;"><%= c.user ? c.user.username : 'Unknown' %></div>
            <div style="font-size:0.88rem;color:#555;margin-top:0.2rem;"><%= c.text %></div>
            <div style="font-size:0.75rem;color:#aaa;margin-top:0.3rem;"><%= new Date(c.createdAt).toLocaleDateString() %></div>
          </div>
          <% if (currUser && c.user && (currUser._id.toString() === c.user._id.toString() || isAdmin)) { %>
          <form method="POST" action="/blogs/<%= blog._id %>/comment/<%= c._id %>?_method=DELETE">
            <button type="submit" style="background:none;border:none;color:#f5576c;cursor:pointer;font-size:0.8rem;padding:0.2rem;">
              <i class="fa-solid fa-trash"></i>
            </button>
          </form>
          <% } %>
        </div>
        <% } %>
      </div>
      <% } else { %>
      <p style="color:#aaa;text-align:center;font-size:0.9rem;padding:1rem 0;">No comments yet. Be the first!</p>
      <% } %>
    </div>

    <div class="mt-3">
      <a href="/blogs" style="color:#667eea;text-decoration:none;font-weight:600;font-size:0.9rem;">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Blogs
      </a>
    </div>
  </div>
</div>

<script>
async function toggleLike() {
  const res = await fetch('/blogs/<%= blog._id %>/like', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
  const data = await res.json();
  document.getElementById('likeCount').textContent = data.likesCount;
  const btn = document.getElementById('likeBtn');
  btn.style.background = data.liked ? 'rgba(245,87,108,0.25)' : 'rgba(245,87,108,0.1)';
}
</script>
