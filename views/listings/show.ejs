<% layout(isAdmin || isLibrarian ? "/layouts/admin" : "/layouts/boilerplate") %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- Book Card -->
      <div class="glass-card overflow-hidden mb-4 anim-up">
        <!-- Hero Image -->
        <div style="position:relative;">
          <img src="<%= listing.image && listing.image.url ? listing.image.url : '' %>" class="show-img" alt="<%= listing.title %>" />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,46,0.7) 0%,transparent 50%);"></div>
          <div style="position:absolute;bottom:1.2rem;left:1.5rem;right:1.5rem;">
            <h2 style="color:#fff;font-weight:800;font-size:1.8rem;text-shadow:0 2px 8px rgba(0,0,0,0.5);margin:0;"><%= listing.title %></h2>
            <span style="color:rgba(255,255,255,0.8);font-size:0.9rem;"><i class="fa-solid fa-user me-1"></i><%= listing.owner ? listing.owner.username : 'Library' %></span>
          </div>
          <!-- Availability badge -->
          <% if (listing.availableQuantity > 0) { %>
          <span class="avail-badge available" style="top:16px;right:16px;"><i class="fa-solid fa-circle-check me-1"></i>Available</span>
          <% } else { %>
          <span class="avail-badge out" style="top:16px;right:16px;"><i class="fa-solid fa-circle-xmark me-1"></i>Out of Stock</span>
          <% } %>
        </div>

        <!-- Book Details -->
        <div class="p-4">
          <div class="row g-3 mb-3">
            <div class="col-sm-6">
              <div style="background:rgba(102,126,234,0.06);border-radius:12px;padding:0.9rem 1rem;">
                <div style="font-size:0.75rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Author</div>
                <div style="font-weight:600;color:#1a1a2e;margin-top:0.2rem;"><i class="fa-solid fa-pen-nib me-2" style="color:#667eea;"></i><%= listing.author || listing.country || 'Unknown' %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div style="background:rgba(79,172,254,0.06);border-radius:12px;padding:0.9rem 1rem;">
                <div style="font-size:0.75rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Location / Shelf</div>
                <div style="font-weight:600;color:#1a1a2e;margin-top:0.2rem;"><i class="fa-solid fa-location-dot me-2" style="color:#4facfe;"></i><%= listing.location %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div style="background:rgba(67,233,123,0.06);border-radius:12px;padding:0.9rem 1rem;">
                <div style="font-size:0.75rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Total Quantity</div>
                <div style="font-weight:600;color:#1a1a2e;margin-top:0.2rem;"><i class="fa-solid fa-layer-group me-2" style="color:#43e97b;"></i><%= listing.totalQuantity || listing.price || 1 %></div>
              </div>
            </div>
            <div class="col-sm-6">
              <div style="background:rgba(250,112,154,0.06);border-radius:12px;padding:0.9rem 1rem;">
                <div style="font-size:0.75rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Available</div>
                <div style="font-weight:600;color:#1a1a2e;margin-top:0.2rem;"><i class="fa-solid fa-book-open me-2" style="color:#fa709a;"></i><%= listing.availableQuantity %> copies</div>
              </div>
            </div>
          </div>

          <% if (listing.description) { %>
          <div style="background:rgba(102,126,234,0.04);border-radius:12px;padding:1rem;margin-bottom:1rem;">
            <div style="font-size:0.75rem;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.4rem;">Description</div>
            <p style="color:#444;line-height:1.7;margin:0;font-size:0.95rem;"><%= listing.description %></p>
          </div>
          <% } %>

          <!-- Action Buttons -->
          <div class="btns">
            <% if (currUser && !isAdmin && !isLibrarian && listing.availableQuantity > 0) { %>
            <form method="POST" action="/borrow/<%= listing._id %>">
              <button type="submit" class="btn btn-grad">
                <i class="fa-solid fa-paper-plane me-2"></i>Request to Borrow
              </button>
            </form>
            <% } else if (currUser && !isAdmin && !isLibrarian && listing.availableQuantity <= 0) { %>
            <span class="badge" style="background:var(--grad-fire);font-size:0.95rem;padding:0.6rem 1.2rem;">
              <i class="fa-solid fa-circle-xmark me-1"></i>Out of Stock
            </span>
            <form method="POST" action="/reservations/<%= listing._id %>">
              <button type="submit" class="btn btn-sm" style="border-radius:50px;background:rgba(250,112,154,0.1);color:#fa709a;border:1px solid rgba(250,112,154,0.3);font-weight:600;margin-top:0.5rem;">
                <i class="fa-solid fa-bookmark me-2"></i>Reserve This Book
              </button>
            </form>
            <% } else { %>
            <a href="/login" class="btn btn-grad"><i class="fa-solid fa-right-to-bracket me-2"></i>Login to Borrow</a>
            <% } %>

            <% if (isAdmin) { %>
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary" style="border-radius:50px;">
              <i class="fa-solid fa-pen me-2"></i>Edit
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button type="submit" class="btn btn-outline-danger" style="border-radius:50px;">
                <i class="fa-solid fa-trash me-2"></i>Delete
              </button>
            </form>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Review Form -->
      <% if (currUser) { %>
      <div class="glass-card p-4 mb-4 anim-up" style="animation-delay:0.15s;">
        <h5 class="section-title"><i class="fa-solid fa-star me-2"></i>Write a Review</h5>
        <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate>
          <div class="mb-3">
            <label class="form-label">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="r1" name="review[rating]" value="1" /><label for="r1" title="Terrible">★</label>
              <input type="radio" id="r2" name="review[rating]" value="2" /><label for="r2" title="Not good">★</label>
              <input type="radio" id="r3" name="review[rating]" value="3" /><label for="r3" title="Average">★</label>
              <input type="radio" id="r4" name="review[rating]" value="4" /><label for="r4" title="Very good">★</label>
              <input type="radio" id="r5" name="review[rating]" value="5" /><label for="r5" title="Amazing">★</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea name="review[comment]" id="comment" rows="3" class="form-control" placeholder="Share your thoughts about this book..." required></textarea>
            <div class="invalid-feedback">Please add a comment.</div>
          </div>
          <button class="btn btn-grad"><i class="fa-solid fa-paper-plane me-2"></i>Submit Review</button>
        </form>
      </div>
      <% } %>

      <!-- All Reviews -->
      <div class="anim-up" style="animation-delay:0.25s;">
        <h5 class="section-title"><i class="fa-solid fa-comments me-2"></i>Reviews (<%= listing.reviews.length %>)</h5>
        <% if (listing.reviews.length === 0) { %>
        <div class="glass-card p-4 text-center" style="color:#aaa;">
          <i class="fa-solid fa-comment-slash" style="font-size:2rem;margin-bottom:0.5rem;display:block;"></i>
          No reviews yet. Be the first to review!
        </div>
        <% } %>
        <div class="row g-3">
          <% for(let review of listing.reviews) { %>
          <div class="col-md-6">
            <div class="card-review">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <span style="font-weight:700;color:#1a1a2e;font-size:0.95rem;">
                    <i class="fa-solid fa-circle-user me-1" style="color:#667eea;"></i><%= review.author.username %>
                  </span>
                  <div style="color:#f5a623;font-size:1rem;margin-top:2px;"><%= '★'.repeat(review.rating) %><span style="color:#ddd;"><%= '★'.repeat(5 - review.rating) %></span></div>
                </div>
                <% if (currUser && (currUser.username === review.author.username || isAdmin)) { %>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm" style="border-radius:50px;background:rgba(245,87,108,0.1);color:#f5576c;border:none;font-size:0.78rem;padding:0.25rem 0.7rem;">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
                <% } %>
              </div>
              <p style="color:#555;font-size:0.9rem;margin:0;line-height:1.6;"><%= review.comment %></p>
            </div>
          </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>
