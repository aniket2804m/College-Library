<% layout(isAdmin || isLibrarian ? "/layouts/admin" : "/layouts/boilerplate") %>

<style>
  .hero-section {
    background: var(--grad-cosmic);
    color: #fff;
    padding: 5rem 0 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    margin: -1rem -12px 0;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(102,126,234,0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(240,147,251,0.25) 0%, transparent 50%),
      radial-gradient(ellipse at 60% 80%, rgba(79,172,254,0.2) 0%, transparent 40%);
    pointer-events: none;
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #fff 0%, #c3cfe2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    position: relative;
  }
  .hero-subtitle { font-size: 1.15rem; opacity: 0.8; margin-bottom: 2.5rem; position: relative; }
  .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; position: relative; }
  .btn-hero-primary {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff; border: none; border-radius: 50px;
    padding: 0.8rem 2rem; font-weight: 700; font-size: 1rem;
    text-decoration: none; transition: all 0.3s;
    box-shadow: 0 4px 20px rgba(102,126,234,0.5);
  }
  .btn-hero-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(102,126,234,0.6); color: #fff; }
  .btn-hero-secondary {
    background: rgba(255,255,255,0.12); color: #fff;
    border: 2px solid rgba(255,255,255,0.4); border-radius: 50px;
    padding: 0.8rem 2rem; font-weight: 700; font-size: 1rem;
    text-decoration: none; transition: all 0.3s; backdrop-filter: blur(8px);
  }
  .btn-hero-secondary:hover { background: rgba(255,255,255,0.22); color: #fff; transform: translateY(-3px); }

  /* Floating orbs */
  .orb { position: absolute; border-radius: 50%; filter: blur(60px); pointer-events: none; }
  .orb-1 { width: 300px; height: 300px; background: rgba(102,126,234,0.25); top: -80px; left: -80px; }
  .orb-2 { width: 250px; height: 250px; background: rgba(240,147,251,0.2); bottom: -60px; right: -60px; }

  /* Feature cards */
  .feat-card {
    background: rgba(255,255,255,0.95);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    transition: all 0.3s ease;
    height: 100%;
    border: 1px solid rgba(255,255,255,0.8);
  }
  .feat-card:hover { transform: translateY(-8px); box-shadow: 0 16px 40px rgba(0,0,0,0.12); }
  .feat-icon {
    width: 64px; height: 64px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.2rem; font-size: 1.6rem; color: #fff;
  }
  .feat-title { font-size: 1.1rem; font-weight: 700; color: #1a1a2e; margin-bottom: 0.6rem; }
  .feat-desc { color: #777; font-size: 0.88rem; line-height: 1.6; }

  /* Stats */
  .stats-band {
    background: var(--grad-primary);
    padding: 3rem 0;
    color: #fff;
  }
  .stat-num { font-size: 2.8rem; font-weight: 800; }
  .stat-lbl { font-size: 0.95rem; opacity: 0.85; }

  /* ── Animated welcome text ── */
  .welcome-line {
    font-size: 1rem; font-weight: 600; letter-spacing: 0.08em;
    color: rgba(255,255,255,0.7); margin-bottom: 0.6rem;
    min-height: 1.4em; position: relative;
  }
  .typed-cursor {
    display: inline-block; width: 2px; height: 1em;
    background: #f093fb; margin-left: 2px;
    animation: blink 0.75s step-end infinite; vertical-align: middle;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* ── Voice stop button ── */
  #voiceStopBtn {
    position: fixed; bottom: 40px; right: 90px; z-index: 1000;
    display: none; align-items: center; gap: 8px;
    background: linear-gradient(135deg,#f5576c,#f093fb);
    border: none; border-radius: 50px; color: #fff;
    padding: 10px 18px; font-size: 0.82rem; font-weight: 700;
    cursor: pointer; box-shadow: 0 4px 20px rgba(245,87,108,0.5);
    animation: voicePulse 1.2s infinite;
  }
  #voiceStopBtn:hover { transform: scale(1.05); }
  @keyframes voicePulse { 0%,100%{box-shadow:0 0 0 0 rgba(245,87,108,0.5)} 50%{box-shadow:0 0 0 10px rgba(245,87,108,0)} }
</style>

<!-- Hero -->
<section class="hero-section">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="container">
    <div class="anim-down">
      <!-- Animated welcome line -->
      <div class="welcome-line">
        <span id="typedWelcome"></span><span class="typed-cursor"></span>
      </div>
      <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:50px;padding:0.4rem 1rem;font-size:0.85rem;margin-bottom:1.5rem;backdrop-filter:blur(8px);">
        <i class="fa-solid fa-sparkles" style="color:#feca57;"></i>
        BookShelf — Siddhant College of Engineering, Pune
      </div>
      <h1 class="hero-title">
        <i class="fa-solid fa-book-open me-2" style="-webkit-text-fill-color:rgba(255,255,255,0.9);"></i>
        BookShelf<br>
        <span style="font-size:0.6em;opacity:0.85;">Siddhant College of Engineering, Pune</span>
      </h1>
      <p class="hero-subtitle">Your digital library — find, borrow, and explore books, e-books, and research papers</p>
      <div class="hero-btns">
        <a href="/listings" class="btn-hero-primary"><i class="fa-solid fa-book me-2"></i>Browse Library</a>
        <a href="/blogs" class="btn-hero-secondary"><i class="fa-solid fa-newspaper me-2"></i>Read Blogs</a>
        <a href="/research" class="btn-hero-secondary"><i class="fa-solid fa-flask me-2"></i>Research Papers</a>
        <button class="va-btn btn-hero-secondary" title="Voice Assistant" style="border:2px solid rgba(255,255,255,0.4);background:rgba(255,255,255,0.12);color:#fff;border-radius:50px;padding:0.8rem 2rem;font-weight:700;font-size:1rem;cursor:pointer;backdrop-filter:blur(8px);transition:all 0.3s;">
          <i class="fa-solid fa-microphone me-2"></i>Voice Search
        </button>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section style="padding:4rem 0;background:#f8f9ff;">
  <div class="container">
    <div class="text-center mb-5 anim-down">
      <h2 style="font-size:2rem;font-weight:800;background:var(--grad-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Platform Features</h2>
      <p style="color:#888;font-size:1rem;">Everything you need for modern library management</p>
    </div>
    <div class="row g-4 anim-up">
      <div class="col-lg-4 col-md-6">
        <div class="feat-card">
          <div class="feat-icon" style="background:var(--grad-primary);"><i class="fa-solid fa-magnifying-glass"></i></div>
          <div class="feat-title">Advanced Search</div>
          <div class="feat-desc">Find books by title, author, or keyword with voice search support.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="feat-card">
          <div class="feat-icon" style="background:var(--grad-ocean);"><i class="fa-solid fa-book-open"></i></div>
          <div class="feat-title">Borrow & Return</div>
          <div class="feat-desc">Seamless borrowing system with due dates, history, and fine tracking.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="feat-card">
          <div class="feat-icon" style="background:var(--grad-forest);"><i class="fa-solid fa-qrcode"></i></div>
          <div class="feat-title">QR Code System</div>
          <div class="feat-desc">Scan QR codes to instantly issue or return books via webcam.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="feat-card">
          <div class="feat-icon" style="background:var(--grad-sunset);"><i class="fa-solid fa-chart-line"></i></div>
          <div class="feat-title">Admin Dashboard</div>
          <div class="feat-desc">Analytics, statistics, and full control over the library system.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="feat-card">
          <div class="feat-icon" style="background:var(--grad-candy);"><i class="fa-solid fa-newspaper"></i></div>
          <div class="feat-title">Blog Platform</div>
          <div class="feat-desc">Create and share knowledge through the integrated blog system.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="feat-card">
          <div class="feat-icon" style="background:var(--grad-lava);"><i class="fa-solid fa-flask"></i></div>
          <div class="feat-title">Research Papers</div>
          <div class="feat-desc">Upload, discover, and download academic research papers.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats Band -->
<section class="stats-band">
  <div class="container">
    <div class="row text-center g-4">
      <div class="col-6 col-lg-3">
        <div class="stat-num">15K+</div>
        <div class="stat-lbl"><i class="fa-solid fa-book me-1"></i>Books in Collection</div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="stat-num">2.5K+</div>
        <div class="stat-lbl"><i class="fa-solid fa-users me-1"></i>Active Students</div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="stat-num">8K+</div>
        <div class="stat-lbl"><i class="fa-solid fa-bookmark me-1"></i>Monthly Borrows</div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="stat-num">98%</div>
        <div class="stat-lbl"><i class="fa-solid fa-circle-check me-1"></i>System Uptime</div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="padding:4rem 0;text-align:center;background:#fff;">
  <div class="container anim-up">
    <h2 style="font-size:2rem;font-weight:800;color:#1a1a2e;margin-bottom:0.8rem;">Ready to get started?</h2>
    <p style="color:#888;font-size:1rem;margin-bottom:2rem;">Join BookShelf and modernize your library experience at Siddhant College of Engineering.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/listings" class="btn btn-grad" style="padding:0.8rem 2rem;font-size:1rem;">
        <i class="fa-solid fa-graduation-cap me-2"></i>Access Library
      </a>
      <% if (!currUser) { %>
      <a href="/signup" class="btn btn-outline-primary" style="border-radius:50px;padding:0.8rem 2rem;font-size:1rem;">
        <i class="fa-solid fa-user-plus me-2"></i>Create Account
      </a>
      <% } %>
    </div>
  </div>
</section>

<!-- Trending Books -->
<section style="padding:3.5rem 0;background:#f8f9ff;">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4 anim-down">
      <div>
        <h3 style="font-size:1.6rem;font-weight:800;background:var(--grad-fire);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin:0;">🔥 Trending Now</h3>
        <p style="color:#888;font-size:0.85rem;margin:0;">Most borrowed books this month</p>
      </div>
      <a href="/listings" style="color:#667eea;font-size:0.85rem;font-weight:600;text-decoration:none;">View all →</a>
    </div>
    <div id="trendingContainer" class="row g-3 anim-up">
      <div class="col-12 text-center py-3"><div class="loader-ring" style="width:36px;height:36px;border-width:3px;margin:0 auto;"></div></div>
    </div>
  </div>
</section>

<!-- Recommended For You -->
<section style="padding:3.5rem 0;background:#fff;">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4 anim-down">
      <div>
        <h3 style="font-size:1.6rem;font-weight:800;background:var(--grad-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin:0;"><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Recommended For You</h3>
        <p id="recReason" style="color:#888;font-size:0.85rem;margin:0;">Personalized picks</p>
      </div>
      <a href="/recommendations" style="color:#667eea;font-size:0.85rem;font-weight:600;text-decoration:none;">See more →</a>
    </div>
    <div id="recContainer" class="row g-3 anim-up">
      <div class="col-12 text-center py-3"><div class="loader-ring" style="width:36px;height:36px;border-width:3px;margin:0 auto;"></div></div>
    </div>
  </div>
</section>

<script>
function buildBookCard(book) {
  const avail = book.availableQuantity > 0
    ? `<span style="color:#43e97b;font-size:0.72rem;font-weight:600;"><i class="fa-solid fa-circle-check me-1"></i>Available</span>`
    : `<span style="color:#f5576c;font-size:0.72rem;font-weight:600;"><i class="fa-solid fa-circle-xmark me-1"></i>Out of Stock</span>`;
  const img = book.image && book.image.url ? book.image.url : '';
  return `<div class="col-6 col-md-4 col-lg-3">
    <a href="/listings/${book._id}" class="text-decoration-none">
      <div class="listing-card h-100" style="cursor:pointer;transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
        ${img ? `<img src="${img}" style="height:160px;width:100%;object-fit:cover;" alt="${book.title}" loading="lazy"/>` : `<div style="height:160px;background:var(--grad-primary);display:flex;align-items:center;justify-content:center;font-size:2rem;">📚</div>`}
        <div class="card-body p-2">
          <p class="card-text mb-0"><b style="font-size:0.85rem;">${book.title}</b>
            <span style="color:#888;font-size:0.75rem;display:block;">${book.author || 'Unknown'}</span>
            <span style="display:block;margin-top:0.2rem;">${avail}</span>
          </p>
        </div>
      </div>
    </a>
  </div>`;
}

// Load trending
fetch('/api/books/trending?limit=8')
  .then(r => r.json())
  .then(data => {
    const c = document.getElementById('trendingContainer');
    if (!data.books || data.books.length === 0) { c.innerHTML = '<div class="col-12 text-center" style="color:#aaa;">No trending data yet.</div>'; return; }
    c.innerHTML = data.books.map(buildBookCard).join('');
  }).catch(() => { document.getElementById('trendingContainer').innerHTML = ''; });

// Load recommendations
fetch('/recommendations/api')
  .then(r => r.json())
  .then(data => {
    const c = document.getElementById('recContainer');
    const r = document.getElementById('recReason');
    if (r && data.reason) r.textContent = data.reason;
    if (!data.recommendations || data.recommendations.length === 0) { c.innerHTML = '<div class="col-12 text-center" style="color:#aaa;"><a href="/listings" style="color:#667eea;">Browse books to get recommendations →</a></div>'; return; }
    c.innerHTML = data.recommendations.slice(0, 8).map(buildBookCard).join('');
  }).catch(() => { document.getElementById('recContainer').innerHTML = ''; });
</script>

<!-- Typing animation for welcome line -->
<script>
(function() {
  const messages = [
    '👋 Welcome to BookShelf!',
    '📚 Discover thousands of books...',
    '🎤 Try Voice Search — just click the mic!',
    '🔥 Check out what\'s trending today...',
    '✨ Your college library, reimagined.',
  ];
  const el = document.getElementById('typedWelcome');
  if (!el) return;

  let msgIdx = 0, charIdx = 0, deleting = false;
  const TYPE_SPEED = 60, DELETE_SPEED = 30, PAUSE = 2000;

  function tick() {
    const current = messages[msgIdx];
    if (!deleting) {
      el.textContent = current.slice(0, ++charIdx);
      if (charIdx === current.length) {
        deleting = true;
        setTimeout(tick, PAUSE);
        return;
      }
    } else {
      el.textContent = current.slice(0, --charIdx);
      if (charIdx === 0) {
        deleting = false;
        msgIdx = (msgIdx + 1) % messages.length;
      }
    }
    setTimeout(tick, deleting ? DELETE_SPEED : TYPE_SPEED);
  }
  setTimeout(tick, 600);
})();
</script>
