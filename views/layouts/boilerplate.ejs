<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>📚 BookShelf — Siddhant College of Engineering, Pune</title>
  <style>body, * { font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif; }</style>
  <link href="/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/all.min.css"/>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/rating.css" />
</head>
<body>

  <%- include("../includes/navbar.ejs") %>

  <!-- Page Loader -->
  <div id="pageLoader">
    <div class="loader-inner">
      <div class="loader-ring"></div>
      <i class="fa-solid fa-book-open loader-icon"></i>
    </div>
  </div>

  <div class="container py-3" style="position:relative;z-index:1;">
    <%- include("../includes/flash.ejs") %>
    <%- body %>
  </div>

  <%- include("../includes/footer.ejs") %>

  <!-- ── Floating buttons (bottom-right) ── -->
  <!-- Stop speaking button — shown only while TTS is active -->
  <button id="voiceStopBtn" onclick="if(window.speechSynthesis){window.speechSynthesis.cancel();document.getElementById('voiceStopBtn').style.display='none';}">
    <i class="fa-solid fa-stop me-1"></i> Stop Speaking
  </button>
  <!-- Voice button sits just below the chatbot button -->
  <button class="va-btn" id="floatingVoiceBtn" title="Voice Assistant">
    <i class="fa-solid fa-microphone"></i>
  </button>

  <!-- AI Chatbot Widget -->
  <div id="chatbotWidget">
    <button id="chatbotToggle" title="AI Library Assistant">
      <i class="fa-solid fa-robot"></i>
    </button>
    <div id="chatbotBox">
      <div id="chatbotHeader">
        <div style="display:flex;align-items:center;gap:0.6rem;">
          <div style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:1rem;"><i class="fa-solid fa-robot"></i></div>
          <div><div style="font-weight:700;font-size:0.9rem;">Library Assistant</div><div style="font-size:0.72rem;opacity:0.8;">AI-powered help</div></div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <button id="chatVoiceToggle" title="Toggle voice reply" onclick="toggleChatVoice()"
            style="background:rgba(255,255,255,0.2);border:none;color:#fff;width:28px;height:28px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:0.8rem;transition:all 0.2s;">
            <i class="fa-solid fa-volume-high"></i>
          </button>
          <button onclick="document.getElementById('chatbotBox').style.display='none'" style="background:none;border:none;color:#fff;font-size:1.1rem;cursor:pointer;padding:0;"><i class="fa-solid fa-xmark"></i></button>
        </div>
      </div>
      <div id="chatbotMessages">
        <div class="bot-msg">👋 Hi! I'm your Library Assistant. Ask me to find books, check availability, or learn about library rules!</div>
      </div>
      <div id="chatbotInput">
        <input type="text" id="chatInput" placeholder="Ask me anything..." />
        <button id="chatSend"><i class="fa-solid fa-paper-plane"></i></button>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="/js/bootstrap.bundle.min.js"></script>

  <!-- Page Loader -->
  <script>
    window.addEventListener('load', () => {
      const loader = document.getElementById('pageLoader');
      if (loader) { loader.style.opacity = '0'; setTimeout(() => loader.style.display = 'none', 400); }
    });
    setTimeout(() => {
      const loader = document.getElementById('pageLoader');
      if (loader) { loader.style.opacity = '0'; loader.style.display = 'none'; }
    }, 2000);
  </script>

  <!-- Chatbot Script -->
  <script>
    const chatbotToggle = document.getElementById('chatbotToggle');
    const chatbotBox    = document.getElementById('chatbotBox');
    const chatInput     = document.getElementById('chatInput');
    const chatMessages  = document.getElementById('chatbotMessages');
    const chatSend      = document.getElementById('chatSend');

    chatbotToggle.addEventListener('click', () => {
      chatbotBox.style.display = chatbotBox.style.display === 'flex' ? 'none' : 'flex';
      if (chatbotBox.style.display === 'flex') chatInput.focus();
    });

    function addMsg(text, type) {
      const div = document.createElement('div');
      div.className = type === 'user' ? 'user-msg' : 'bot-msg';
      div.innerHTML = text;
      chatMessages.appendChild(div);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    async function sendChat() {
      const msg = chatInput.value.trim();
      if (!msg) return;
      addMsg(msg, 'user');
      chatInput.value = '';
      addMsg('<i class="fa-solid fa-circle-notch fa-spin"></i> Thinking...', 'bot');
      try {
        const res = await fetch('/api/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
        const data = await res.json();
        chatMessages.lastChild.remove();
        addMsg(data.reply, 'bot');
        if (data.action === 'redirect' && data.url) setTimeout(() => { window.location.href = data.url; }, 1500);
        if (window.chatVoiceEnabled && window.voiceBotSpeak) window.voiceBotSpeak(data.reply);
      } catch(e) {
        chatMessages.lastChild.remove();
        addMsg('Sorry, I encountered an error. Please try again.', 'bot');
      }
    }

    chatSend.addEventListener('click', sendChat);
    chatInput.addEventListener('keydown', e => { if (e.key === 'Enter') sendChat(); });

    // Voice toggle for chatbot
    window.chatVoiceEnabled = true;
    window.toggleChatVoice = function() {
      window.chatVoiceEnabled = !window.chatVoiceEnabled;
      const btn = document.getElementById('chatVoiceToggle');
      if (btn) {
        btn.innerHTML = window.chatVoiceEnabled
          ? '<i class="fa-solid fa-volume-high"></i>'
          : '<i class="fa-solid fa-volume-xmark"></i>';
        btn.style.background = window.chatVoiceEnabled ? 'rgba(255,255,255,0.2)' : 'rgba(255,255,255,0.05)';
        btn.style.opacity = window.chatVoiceEnabled ? '1' : '0.5';
        btn.title = window.chatVoiceEnabled ? 'Voice ON — click to mute' : 'Voice OFF — click to unmute';
      }
      // Stop any current speech if muting
      if (!window.chatVoiceEnabled && window.speechSynthesis) window.speechSynthesis.cancel();
    };
  </script>

  <style>
    /* ── Voice stop button ── */
    #voiceStopBtn {
      position: fixed; bottom: 40px; right: 90px; z-index: 1000;
      display: none; align-items: center; gap: 6px;
      background: linear-gradient(135deg,#f5576c,#f093fb);
      border: none; border-radius: 50px; color: #fff;
      padding: 10px 18px; font-size: 0.82rem; font-weight: 700;
      cursor: pointer; box-shadow: 0 4px 20px rgba(245,87,108,0.5);
      animation: voicePulse 1.2s infinite;
    }
    #voiceStopBtn:hover { transform: scale(1.05); }

    /* ── Floating voice button ── */
    #floatingVoiceBtn {
      position: fixed; bottom: 40px; right: 28px; z-index: 999;
      width: 52px; height: 52px; border-radius: 50%;
      background: var(--grad-primary); border: none; color: #fff;
      font-size: 1.2rem; cursor: pointer;
      box-shadow: 0 4px 20px rgba(102,126,234,0.5);
      transition: all 0.3s; display: flex; align-items: center; justify-content: center;
    }
    #floatingVoiceBtn:hover { transform: scale(1.1); box-shadow: 0 8px 28px rgba(102,126,234,0.65); }
    #floatingVoiceBtn.va-listening { background: var(--grad-fire) !important; animation: voicePulse 1.2s infinite; }

    /* ── Chatbot widget ── */
    #chatbotWidget { position: fixed; bottom: 100px; right: 28px; z-index: 998; }
    #chatbotToggle { width: 52px; height: 52px; border-radius: 50%; background: var(--grad-candy); border: none; color: #fff; font-size: 1.3rem; cursor: pointer; box-shadow: 0 4px 20px rgba(161,140,209,0.5); transition: all 0.3s; display: flex; align-items: center; justify-content: center; }
    #chatbotToggle:hover { transform: scale(1.1); }
    #chatbotBox { display: none; flex-direction: column; position: absolute; bottom: 64px; right: 0; width: 320px; height: 420px; background: #fff; border-radius: 20px; box-shadow: 0 16px 48px rgba(0,0,0,0.18); overflow: hidden; border: 1px solid rgba(255,255,255,0.8); }
    #chatbotHeader { background: var(--grad-primary); padding: 1rem; color: #fff; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    #chatbotMessages { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 0.6rem; background: #f8f9ff; }
    .bot-msg { background: #fff; border-radius: 12px 12px 12px 4px; padding: 0.7rem 0.9rem; font-size: 0.85rem; color: #333; box-shadow: 0 2px 8px rgba(0,0,0,0.06); max-width: 90%; line-height: 1.5; }
    .user-msg { background: var(--grad-primary); color: #fff; border-radius: 12px 12px 4px 12px; padding: 0.7rem 0.9rem; font-size: 0.85rem; align-self: flex-end; max-width: 85%; }
    #chatbotInput { display: flex; gap: 0.5rem; padding: 0.8rem; background: #fff; border-top: 1px solid #f0f0f0; flex-shrink: 0; }
    #chatInput { flex: 1; border: 1.5px solid #e0e0f0; border-radius: 50px; padding: 0.5rem 1rem; font-size: 0.85rem; outline: none; }
    #chatInput:focus { border-color: #667eea; }
    #chatSend { width: 36px; height: 36px; border-radius: 50%; background: var(--grad-primary); border: none; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; flex-shrink: 0; }
    #chatSend:hover { transform: scale(1.1); }

    /* ── Page Loader ── */
    #pageLoader { position: fixed; inset: 0; background: linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%); display: flex; align-items: center; justify-content: center; z-index: 9999; transition: opacity 0.4s ease; }
    .loader-inner { position: relative; display: flex; align-items: center; justify-content: center; }
    .loader-ring { width: 70px; height: 70px; border-radius: 50%; border: 4px solid transparent; border-top-color: #667eea; border-right-color: #f093fb; animation: spin 1s linear infinite; }
    .loader-icon { position: absolute; font-size: 1.6rem; background: linear-gradient(135deg,#667eea,#f093fb); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes voicePulse { 0%,100%{box-shadow:0 0 0 0 rgba(245,87,108,0.5)} 50%{box-shadow:0 0 0 10px rgba(245,87,108,0)} }
  </style>

  <!-- Main Script -->
  <script src="/js/script.js"></script>
  <!-- Always-On Voice Bot (click-to-activate) -->
  <script src="/js/alwaysOnVoiceBot.js"></script>

</body>
</html>
