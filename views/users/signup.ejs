<% layout("/layouts/boilerplate") %>

<style>
  .auth-page { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
  .auth-card { width: 100%; max-width: 440px; background: rgba(255,255,255,0.95); backdrop-filter: blur(20px); border-radius: 24px; box-shadow: 0 20px 60px rgba(240,147,251,0.2), 0 8px 24px rgba(0,0,0,0.1); border: 1px solid rgba(255,255,255,0.8); overflow: hidden; animation: scaleIn 0.5s ease both; }
  .auth-header { background: var(--grad-fire); padding: 2rem; text-align: center; color: #fff; }
  .auth-header h1 { font-size: 1.8rem; font-weight: 800; margin: 0.5rem 0 0.3rem; }
  .auth-header p { opacity: 0.85; font-size: 0.92rem; margin: 0; }
  .auth-icon { width: 60px; height: 60px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 0.5rem; font-size: 1.6rem; }
  .auth-body { padding: 2rem; }
  .auth-body .form-control { border-radius: 12px !important; border: 1.5px solid #e0e0f0 !important; padding: 0.75rem 1rem !important; font-size: 0.95rem; transition: all 0.3s; }
  .auth-body .form-control:focus { border-color: #f5576c !important; box-shadow: 0 0 0 3px rgba(245,87,108,0.15) !important; }
  .btn-auth { background: var(--grad-fire); color: #fff; border: none; border-radius: 50px; padding: 0.75rem; font-weight: 700; font-size: 1rem; width: 100%; transition: all 0.3s; box-shadow: 0 4px 15px rgba(245,87,108,0.4); cursor: pointer; }
  .btn-auth:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(245,87,108,0.5); color: #fff; }
  .input-icon-wrap { position: relative; }
  .input-icon-wrap .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #f5576c; font-size: 0.9rem; z-index: 1; }
  .input-icon-wrap .form-control { padding-left: 2.5rem !important; }
  .role-student { background: rgba(102,126,234,0.08); border-left: 3px solid #667eea; border-radius: 10px; padding: 0.5rem 0.8rem; font-size: 0.82rem; color: #667eea; margin-top: 0.4rem; display: none; }
  .role-librarian { background: rgba(67,233,123,0.08); border-left: 3px solid #43e97b; border-radius: 10px; padding: 0.5rem 0.8rem; font-size: 0.82rem; color: #2d8a5e; margin-top: 0.4rem; display: none; }
</style>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-icon"><i class="fa-solid fa-user-plus"></i></div>
      <h1>Create Account</h1>
      <p>Join BookShelf — Siddhant College of Engineering</p>
    </div>
    <div class="auth-body">
      <form action="/signup" method="POST">

        <div class="mb-3">
          <label for="username" class="form-label fw-semibold" style="color:#1a1a2e;">Username</label>
          <div class="input-icon-wrap">
            <i class="fa-solid fa-user input-icon"></i>
            <input name="username" id="username" type="text" class="form-control" placeholder="Choose a username" required />
          </div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label fw-semibold" style="color:#1a1a2e;">Email</label>
          <div class="input-icon-wrap">
            <i class="fa-solid fa-envelope input-icon"></i>
            <input name="email" id="email" type="email" class="form-control" placeholder="Enter your email" required />
          </div>
        </div>

        <div class="mb-3">
          <label for="role" class="form-label fw-semibold" style="color:#1a1a2e;">Register As</label>
          <div class="input-icon-wrap">
            <i class="fa-solid fa-id-badge input-icon"></i>
            <select name="role" id="roleSelect" class="form-control" onchange="showRoleInfo(this.value)">
              <option value="user">🎓 Student</option>
              <option value="librarian">📚 Librarian</option>
            </select>
          </div>
          <div class="role-student" id="infoStudent">
            <i class="fa-solid fa-circle-info me-1"></i>Students can borrow books, write reviews, and access the full library catalog.
          </div>
          <div class="role-librarian" id="infoLibrarian">
            <i class="fa-solid fa-circle-info me-1"></i>Librarians can manage books, approve research papers, and access the admin dashboard.
          </div>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label fw-semibold" style="color:#1a1a2e;">Password</label>
          <div class="input-icon-wrap">
            <i class="fa-solid fa-lock input-icon"></i>
            <input name="password" id="password" type="password" class="form-control" placeholder="Create a password" required />
          </div>
        </div>

        <button type="submit" class="btn-auth">
          <i class="fa-solid fa-user-plus me-2"></i>Create Account
        </button>
      </form>

      <div class="text-center mt-4" style="color:#888;font-size:0.9rem;">
        Already have an account?
        <a href="/login" style="color:#f5576c;font-weight:600;text-decoration:none;"> Login here</a>
      </div>
    </div>
  </div>
</div>

<script>
  function showRoleInfo(val) {
    document.getElementById('infoStudent').style.display   = val === 'user'      ? 'block' : 'none';
    document.getElementById('infoLibrarian').style.display = val === 'librarian' ? 'block' : 'none';
  }
  // Show on load
  showRoleInfo(document.getElementById('roleSelect').value);
</script>
