<% layout(isAdmin || isLibrarian ? "/layouts/admin" : "/layouts/boilerplate") %>

<div class="anim-down mb-4 d-flex justify-content-between align-items-center">
  <div>
    <h2 class="section-title mb-1"><i class="fa-solid fa-clock-rotate-left me-2"></i>Borrow History</h2>
    <p style="color:#888;font-size:0.9rem;">All your past and current borrow records</p>
  </div>
  <a href="/borrow/current" class="btn btn-grad"><i class="fa-solid fa-bookmark me-2"></i>Current Borrows</a>
</div>

<% if (!records || records.length === 0) { %>
<div class="glass-card p-5 text-center anim-up">
  <div style="font-size:3rem;margin-bottom:1rem;">📋</div>
  <h5 style="color:#555;font-weight:600;">No history yet</h5>
  <p style="color:#aaa;font-size:0.9rem;">Your borrow history will appear here.</p>
  <a href="/listings" class="btn btn-grad mt-2"><i class="fa-solid fa-book me-2"></i>Browse Books</a>
</div>
<% } else { %>
<div class="glass-card p-4 anim-up">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead style="background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;">
        <tr>
          <th>Book</th>
          <th>Issued</th>
          <th>Due</th>
          <th>Returned</th>
          <th>Fine</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% for (let b of records) { %>
        <tr>
          <td style="font-weight:600;color:#1a1a2e;"><%= b.book ? b.book.title : 'N/A' %></td>
          <td style="font-size:0.85rem;color:#666;"><%= b.issueDate ? new Date(b.issueDate).toLocaleDateString() : '-' %></td>
          <td style="font-size:0.85rem;color:#666;"><%= b.dueDate ? new Date(b.dueDate).toLocaleDateString() : '-' %></td>
          <td style="font-size:0.85rem;color:#666;"><%= b.returnDate ? new Date(b.returnDate).toLocaleDateString() : '-' %></td>
          <td>
            <% if (b.fineAmount > 0) { %>
            <span style="color:#f5576c;font-weight:600;">₹<%= b.fineAmount %></span>
            <% } else { %>
            <span style="color:#43e97b;font-weight:600;">₹0</span>
            <% } %>
          </td>
          <td>
            <% if (b.status === 'Returned') { %>
            <span class="badge" style="background:var(--grad-forest);">Returned</span>
            <% } else if (b.status === 'Overdue') { %>
            <span class="badge" style="background:var(--grad-fire);">Overdue</span>
            <% } else { %>
            <span class="badge" style="background:var(--grad-sunset);">Active</span>
            <% } %>
          </td>
          <td>
            <% if (b.status === 'Overdue' && b.fineAmount > 0 && !b.finePaid) { %>
            <form method="POST" action="/borrow/<%= b._id %>/pay-fine">
              <button class="btn btn-sm btn-danger" style="border-radius:50px;font-size:0.75rem;">
                <i class="fa-solid fa-money-bill me-1"></i>Pay Fine
              </button>
            </form>
            <% } else if (b.finePaid) { %>
            <span style="color:#43e97b;font-size:0.78rem;font-weight:600;"><i class="fa-solid fa-check me-1"></i>Paid</span>
            <% } %>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
<nav class="mt-4">
  <ul class="pagination justify-content-center">
    <% for (let i = 1; i <= totalPages; i++) { %>
    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
      <a class="page-link" href="?page=<%= i %>"><%= i %></a>
    </li>
    <% } %>
  </ul>
</nav>
<% } %>
<% } %>
