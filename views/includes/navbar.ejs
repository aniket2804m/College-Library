<style>
  .custom-navbar { background: var(--grad-navbar) !important; box-shadow: 0 4px 24px rgba(0,0,0,0.35); padding: 0.55rem 0; }
  .navbar-brand { font-size: 1.5rem !important; font-weight: 800 !important; background: linear-gradient(135deg, #667eea, #f093fb, #4facfe) !important; -webkit-background-clip: text !important; -webkit-text-fill-color: transparent !important; background-clip: text !important; }
  .nav-pill { border-radius: 20px !important; padding: 0.35rem 0.85rem !important; font-size: 0.85rem !important; font-weight: 500 !important; color: rgba(255,255,255,0.85) !important; transition: all 0.25s ease !important; margin: 0 1px; }
  .nav-pill:hover { background: rgba(255,255,255,0.14) !important; color: #fff !important; transform: translateY(-1px); }
  #searchInput::placeholder { color: rgba(255,255,255,0.5); }
  #searchInput:focus { outline: none; box-shadow: 0 0 0 2px rgba(102,126,234,0.5); background: rgba(255,255,255,0.18) !important; }
  .suggestion-item { padding: 0.55rem 1rem; cursor: pointer; font-size: 0.9rem; color: #333; transition: background 0.2s; }
  .suggestion-item:hover { background: rgba(102,126,234,0.08); }
  #voiceSearchBtn:hover { transform: scale(1.15); }
  #voiceSearchBtn.listening { background: var(--grad-fire) !important; animation: voicePulse 1.5s infinite; }
  .va-btn.va-listening { background: var(--grad-fire) !important; animation: voicePulse 1.5s infinite; }
  @keyframes voicePulse { 0%,100% { box-shadow: 0 0 0 0 rgba(245,87,108,0.5); } 50% { box-shadow: 0 0 0 8px rgba(245,87,108,0); } }
</style>

<script>
  // ── Search bar autocomplete ──────────────────────────────────────────────
  const searchInput = document.getElementById("searchInput");
  const suggestionsBox = document.getElementById("suggestions");
  const sampleBooks = ["Python Crash Course","Effective Java","Clean Code","The Pragmatic Programmer","Design Patterns","Head First JavaScript","You Don't Know JS","Operating System Concepts","Database System Concepts","Artificial Intelligence","Deep Learning with Python","Data Structures and Algorithms","Programming Rust","Go Programming Language"];
  if (searchInput) {
    searchInput.addEventListener("input", function () {
      const query = this.value.toLowerCase(); suggestionsBox.innerHTML = "";
      if (query.length > 0) {
        const filtered = sampleBooks.filter(b => b.toLowerCase().includes(query));
        if (filtered.length > 0) { filtered.forEach(book => { const div = document.createElement("div"); div.className = "suggestion-item"; div.textContent = book; div.onclick = () => { searchInput.value = book; suggestionsBox.style.display = "none"; goSearch(book); }; suggestionsBox.appendChild(div); }); suggestionsBox.style.display = "block"; } else { suggestionsBox.style.display = "none"; }
      } else { suggestionsBox.style.display = "none"; }
    });
    searchInput.addEventListener("keydown", function(e) {
      if (e.key === "Enter" && this.value.trim()) {
        suggestionsBox.style.display = "none";
        goSearch(this.value.trim());
      }
    });
    document.addEventListener("click", e => { if (!searchInput.contains(e.target) && !suggestionsBox.contains(e.target)) suggestionsBox.style.display = "none"; });
  }

  function goSearch(term) {
    window.location.href = `/listings?search=${encodeURIComponent(term)}`;
  }

  // ── Search bar mic — voice-to-search only ────────────────────────────────
  const voiceSearchBtn = document.getElementById("voiceSearchBtn");
  let vsRec = null, vsOn = false;
  if (('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) && voiceSearchBtn) {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    vsRec = new SR();
    vsRec.continuous = false; vsRec.interimResults = false; vsRec.lang = 'en-US';
    vsRec.onstart = () => { vsOn = true; voiceSearchBtn.classList.add('listening'); voiceSearchBtn.innerHTML = '<i class="fa-solid fa-stop"></i>'; };
    vsRec.onend   = () => { vsOn = false; voiceSearchBtn.classList.remove('listening'); voiceSearchBtn.innerHTML = '<i class="fa-solid fa-microphone"></i>'; };
    vsRec.onerror = () => { vsOn = false; voiceSearchBtn.classList.remove('listening'); voiceSearchBtn.innerHTML = '<i class="fa-solid fa-microphone"></i>'; };
    vsRec.onresult = e => {
      const transcript = e.results[0][0].transcript.trim();
      // Strip common search prefixes, then redirect to listings search
      const term = transcript.replace(/^(search for|find|show me|books about|search)\s+/i, '').trim();
      if (searchInput) searchInput.value = term;
      goSearch(term);
    };
    voiceSearchBtn.addEventListener('click', () => vsOn ? vsRec.stop() : vsRec.start());
  } else if (voiceSearchBtn) {
    voiceSearchBtn.style.display = 'none';
  }
</script>
